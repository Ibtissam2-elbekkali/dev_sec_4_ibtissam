<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/background_ibtissam">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvExternalTitle_ibtissam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stockage Externe (Scoped Storage)"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvExternalDesc_ibtissam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Utilise getExternalFilesDir() pour le stockage spécifique à l'application."
            android:textColor="#BBBBBB"
            app:layout_constraintTop_toBottomOf="@id/tvExternalTitle_ibtissam" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilExtFilename_ibtissam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Nom du fichier"
            android:textColorHint="#AAAAAA"
            app:layout_constraintTop_toBottomOf="@id/tvExternalDesc_ibtissam">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etExtFilename_ibtissam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilExtContent_ibtissam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Contenu"
            android:textColorHint="#AAAAAA"
            app:layout_constraintTop_toBottomOf="@id/tilExtFilename_ibtissam">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etExtContent_ibtissam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="textMultiLine"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/extButtonContainer_ibtissam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tilExtContent_ibtissam">

            <Button
                android:id="@+id/btnExtSave_ibtissam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enregistrer"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/primary_ibtissam"/>

            <Button
                android:id="@+id/btnExtLoad_ibtissam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Charger"
                android:layout_marginStart="4dp"
                android:backgroundTint="@color/primary_ibtissam"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvExtFileContent_ibtissam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/surface_ibtissam"
            android:padding="8dp"
            android:minHeight="100dp"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/extButtonContainer_ibtissam" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>